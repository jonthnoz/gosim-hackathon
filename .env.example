# MiniMax — single key powers script (MiniMax-M2), TTS (speech-2.8-hd),
# image (image-01), and music (music-2.6). All four modalities run
# against api.minimax.io with one Bearer token.
# Sign up at https://platform.minimax.io. Use either a "Token Plan Key"
# (prepaid bundle) or a "Create new secret key" (pay-as-you-go) — both
# are functionally identical. The international api.minimax.io uses
# Bearer-only auth; no GroupId needed (that was the older China API).
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io

# Supabase — Postgres + Storage for listings, generated reels, and blobs.
# Service-role key is server-side only; never ship to the browser.
# HTTPS API URL (Project Settings → API → Project URL).
SUPABASE_URL=
# Server-side key. Either the new "Create secret key" (sb_secret_...) or the legacy "service_role" eyJ...
SUPABASE_SERVICE_ROLE_KEY=
# Browser-safe key. Either the new "publishable" (sb_publishable_...) or the legacy "anon" eyJ...
SUPABASE_ANON_KEY=
# Postgres connection string (Project Settings → Database → Connection string). Used only by psql for migrations.
SUPABASE_DB_URL=
# Mirrors of the above two for the Next.js client (browser-readable).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Inside Airbnb Paris snapshot — discover the current date from
# https://insideairbnb.com/get-the-data/ ; pin here for reproducibility.
INSIDE_AIRBNB_SNAPSHOT_DATE=2025-09-12
